{
  "name": "master-skill-orchestrator",
  "version": "0.1.1",
  "description": "CLI to orchestrate agent skills and AI framework installation across projects.",
  "main": "dist/cli.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check",
    "release:check": "npm run check && npm pack --dry-run"
  },
  "keywords": [
    "cli",
    "codex",
    "claude",
    "skills",
    "agents",
    "frameworks"
  ],
  "author": "jamesmetals",
  "license": "ISC",
  "type": "module",
  "bin": {
    "master-skill": "dist/cli.js",
    "master-skill-orchestrator": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jamesmetals/master-skill-orchestrato.git"
  },
  "homepage": "https://github.com/jamesmetals/master-skill-orchestrato#readme",
  "bugs": {
    "url": "https://github.com/jamesmetals/master-skill-orchestrato/issues"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.2",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "npm@11.3.0"
}
